---
layout: null
---
[
  {% for post in site.posts %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": "{{ post.date | date: '%Y.%m.%d' }}",
    "categories": "{{ post.categories | join: ' · ' }}",
    "tags": "{{ post.tags | join: ', ' }}",
    "content": {{ post.description | default: post.excerpt | strip_html | truncatewords: 30 | jsonify }}
  },
  {% endfor %}
  {% assign pages = site.pages | where_exp: "item", "item.title != nil" %}
  {% for page in pages %}
  {
    "title": {{ page.title | jsonify }},
    "url": {{ page.url | relative_url | jsonify }},
    "date": "",
    "categories": "Page",
    "tags": "",
    "content": {{ page.description | default: page.excerpt | strip_html | truncatewords: 30 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
